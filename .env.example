# App Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/osi-dashboard

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# Session Secret (required for Microsoft SSO)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here_change_this_in_production

# Microsoft Azure AD Configuration
AZURE_CLIENT_ID=your_azure_client_id_from_azure_portal
AZURE_CLIENT_SECRET=your_azure_client_secret_from_azure_portal
AZURE_TENANT_ID=your_azure_tenant_id_from_azure_portal
AZURE_REDIRECT_URI=http://localhost:4000/api-dashboard/auth/sso/microsoft/callback

# Encryption Key (for storing Microsoft tokens - use 32 character hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# SSO Role Configuration (Optional)
# Comma-separated list of email addresses for different roles
# Admin users (full access to all features)
SSO_ADMIN_EMAILS=admin@company.com,boss@company.com
# Editor users (can manage apps but not users)
SSO_EDITOR_EMAILS=editor1@company.com,editor2@company.com
# All other SSO users will be assigned "viewer" role by default

# ============================================
# AI Chatbot Configuration (Optional)
# ============================================
# Set to 'true' to enable AI fallback when pattern matching fails
# Requires OPENAI_API_KEY to be set
ENABLE_AI_FALLBACK=false

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# Only required if ENABLE_AI_FALLBACK=true
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model to use (optional, defaults to gpt-4o-mini for cost efficiency)
# Options: gpt-4o-mini (cheap), gpt-4o (powerful), gpt-3.5-turbo (legacy)
OPENAI_MODEL=gpt-4o-mini
